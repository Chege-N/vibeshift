# ============================================================
# RepurposeAI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── App ──────────────────────────────────────────────────────
APP_NAME=RepurposeAI
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=repurposeai
POSTGRES_USER=repurposeai
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://repurposeai:change-me-strong-password@postgres:5432/repurposeai

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── AI / LLM ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Transcription ────────────────────────────────────────────
ASSEMBLYAI_API_KEY=your-assemblyai-key-here

# ── Payments ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_AGENCY_PRICE_ID=price_agency_monthly

# ── Storage ──────────────────────────────────────────────────
# Local storage (dev) or S3-compatible (prod)
STORAGE_TYPE=local            # local | s3
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500

# AWS S3 (if STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=repurposeai-uploads
AWS_REGION=us-east-1

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@repurposeai.com
FROM_NAME=RepurposeAI

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
VITE_APP_NAME=RepurposeAI

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
FREE_TIER_MONTHLY_CREDITS=3
STARTER_TIER_MONTHLY_CREDITS=30
PRO_TIER_MONTHLY_CREDITS=100
